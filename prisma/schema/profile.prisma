model TechnicianProfile {
    id String @id @default(uuid())

    userId String @unique
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    bio String?
    experience String @default("")
    location String @default("")
    hourlyRate  Float?

    availability Availability[]

    averageRating Float @default(0)
    totalReviews  Int   @default(0)
    completedJobs Int   @default(0)

    services Service[]
// Bookings received by the technician
    bookings Booking[] @relation("TechnicianBookings")

 // Reviews received by the technician
    reviews Review[] @relation("TechnicianReviews")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

@@map("technicianProfiles")
}

model Availability {
    id String @id @default (uuid())

    technicianId String 
    technician TechnicianProfile @relation(fields: [technicianId], references: [id], onDelete: Cascade)

    dayOfWeek Int
    startTime DateTime
    endTime DateTime

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt


    @@map("availabilities")
}